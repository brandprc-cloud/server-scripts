{
  "statusLine": {
    "type": "command",
    "command": "bash /home/claudeuser/.claude/statusline-command.sh"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo -e '\\a'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo -e '\\a\\a'"
          }
        ]
      }
    ]
  }
}
