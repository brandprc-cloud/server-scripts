{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo -e '\\a'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo -e '\\a\\a'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /home/claudeuser/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "telegram@local-plugins": false
  },
  "extraKnownMarketplaces": {
    "local-plugins": {
      "source": {
        "source": "directory",
        "path": "/home/claudeuser/.claude/plugins/marketplaces/local-plugins"
      }
    }
  },
  "theme": "dark"
}
